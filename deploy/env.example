# /etc/gh-desktop-receiver/env
#
# Generate values once with:
#   gh-desktop-receiver --gen-secrets
#
# WEBHOOK_SECRET goes into your GitHub webhook "Secret" field.
# SUBSCRIBER_TOKEN goes into the desktop app's Settings → webhook_remote_url
# (use https://your-host/events?token=<this>).

GH_DESKTOP_RECEIVER_WEBHOOK_SECRET=replace-me-with-token-hex-64
GH_DESKTOP_RECEIVER_SUBSCRIBER_TOKEN=replace-me-with-token-urlsafe-32
GH_DESKTOP_RECEIVER_HOST=127.0.0.1
GH_DESKTOP_RECEIVER_PORT=8765
GH_DESKTOP_RECEIVER_DB_PATH=/var/lib/gh-desktop-receiver/events.db
GH_DESKTOP_RECEIVER_RETENTION_DAYS=14
