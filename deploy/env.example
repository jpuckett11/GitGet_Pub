# /etc/gitget-receiver/env
#
# Generate values once with:
#   gitget-receiver --gen-secrets
#
# WEBHOOK_SECRET goes into your GitHub webhook "Secret" field.
# SUBSCRIBER_TOKEN goes into the desktop app's Settings → webhook_remote_url
# (use https://your-host/events?token=<this>).

GITGET_RECEIVER_WEBHOOK_SECRET=replace-me-with-token-hex-64
GITGET_RECEIVER_SUBSCRIBER_TOKEN=replace-me-with-token-urlsafe-32
GITGET_RECEIVER_HOST=127.0.0.1
GITGET_RECEIVER_PORT=8765
GITGET_RECEIVER_DB_PATH=/var/lib/gitget-receiver/events.db
GITGET_RECEIVER_RETENTION_DAYS=14
